{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "TransLens",
  "version": "1.0.0",
  "identifier": "com.translens.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "TransLens - 智能划词翻译助手",
        "width": 420,
        "height": 680,
        "minWidth": 360,
        "minHeight": 480,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "center": true,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "visible": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "sql": {
      "preload": ["sqlite:translens.db"]
    }
  }
}
